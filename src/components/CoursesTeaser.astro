---
import SectionHead from "./SectionHead.astro";
import { getCollection } from "astro:content";
import { COURSE_CAT_IDS, COURSE_CAT_META } from "../data/course-cats";
import { courseIntro } from "../data/site";
import { withBase } from "../lib/site";

const courses = await getCollection("courses");
const count = (id: string) => courses.filter((c) => c.data.cat === id).length;
---

<section class="section" id="courses">
  <div class="wrap">
    <SectionHead zh="企業資安課程" en="Courses for Business" />
    <p class="courses-intro">{courseIntro}</p>
    <div class="cat-grid">
      {
        COURSE_CAT_IDS.map((id) => (
          <a class={"cat-card cat-" + id} href={withBase("/courses?cat=" + id)}>
            <span class="cat-card-ico">
              <i class={COURSE_CAT_META[id].icon} aria-hidden="true" />
            </span>
            <span class="cat-card-name">{COURSE_CAT_META[id].label}</span>
            <span class="cat-card-desc">{COURSE_CAT_META[id].blurb}</span>
            <span class="cat-card-count">{count(id)} 門課程</span>
            <span class="cat-card-go">
              查看課程 <i class="fa-solid fa-arrow-right" aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>
    <div class="courses-foot">
      <p>所有課程皆可依企業需求客製安排內訓。</p>
      <div class="courses-foot-cta">
        <a class="btn btn-primary" href={withBase("/courses")}>
          瀏覽完整課程 <i class="fa-solid fa-arrow-right" aria-hidden="true"
          ></i>
        </a>
        <a class="btn btn-ghost" href="#contact">洽詢企業內訓</a>
      </div>
    </div>
  </div>
</section>
