---
import SectionHead from "./SectionHead.astro";
import { courseCats, courses, courseIntro } from "../data/site";
import { withBase } from "../lib/site";

const cats = courseCats.filter((c) => c.id !== "all");
const count = (id: string) => courses.filter((c) => c.cat === id).length;
const icon: Record<string, string> = {
  awareness: "fa-solid fa-user-shield",
  offensive: "fa-solid fa-bug",
  defensive: "fa-solid fa-shield-halved",
};
const blurb: Record<string, string> = {
  awareness: "全員適用、無技術門檻，建立日常防護直覺",
  offensive: "技術人員的滲透測試與紅隊實戰",
  defensive: "防禦維運、DevSecOps、雲端與事件應變",
};
---

<section class="section" id="courses">
  <div class="wrap">
    <SectionHead zh="企業資安課程" en="Courses for Business" />
    <p class="courses-intro">{courseIntro}</p>
    <div class="cat-grid">
      {
        cats.map((c) => (
          <a class={"cat-card cat-" + c.id} href={withBase("/courses?cat=" + c.id)}>
            <span class="cat-card-ico">
              <i class={icon[c.id]} />
            </span>
            <span class="cat-card-name">{c.label}</span>
            <span class="cat-card-desc">{blurb[c.id]}</span>
            <span class="cat-card-count">{count(c.id)} 門課程</span>
            <span class="cat-card-go">
              查看課程 <i class="fa-solid fa-arrow-right" />
            </span>
          </a>
        ))
      }
    </div>
    <div class="courses-foot">
      <p>所有課程皆可依企業需求客製安排內訓。</p>
      <div class="courses-foot-cta">
        <a class="btn btn-primary" href={withBase("/courses")}>
          瀏覽完整課程 <i class="fa-solid fa-arrow-right"></i>
        </a>
        <a class="btn btn-ghost" href="#contact">洽詢企業內訓</a>
      </div>
    </div>
  </div>
</section>
