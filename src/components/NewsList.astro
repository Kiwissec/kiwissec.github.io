---
import NewsCard from "./NewsCard.astro";
import { getCollection } from "astro:content";
import { withBase } from "../lib/site";

const news = (await getCollection("news")).sort((a, b) =>
  b.data.date.localeCompare(a.data.date),
);
const tags = ["全部", ...Array.from(new Set(news.map((n) => n.data.tag)))];
const count = (t: string) => news.filter((n) => n.data.tag === t).length;
---

<header class="page-head">
  <div class="page-head-bg" aria-hidden="true">
    <span class="blob blob-cream"></span>
    <span class="blob blob-kiwi"></span>
    <span class="hero-hex"></span>
  </div>
  <div class="wrap page-head-inner">
    <nav class="crumbs">
      <a href={withBase("/")}>首頁</a>
      <span>/</span> 最新消息
    </nav>
    <h1>最新消息</h1>
    <p>七維思的活動快訊、課程與社群動態 —— 看看奇異鳥們最近都在忙些什麼。</p>
  </div>
</header>

<section class="section section-flush" id="all-news">
  <div class="wrap">
    {
      /* 篩選器語意（toggle button + aria-pressed），非 ARIA tabs：理由同
        CoursesCatalog。 */
    }
    <div class="course-tabs" role="group" aria-label="消息分類">
      {
        tags.map((t, i) => (
          <button
            class={"course-tab" + (i === 0 ? " is-active" : "")}
            data-tag={t}
            aria-pressed={i === 0 ? "true" : "false"}
          >
            {t}
            {t !== "全部" && <span class="tab-count">{count(t)}</span>}
          </button>
        ))
      }
    </div>

    <div class="news-grid">
      {news.map((n) => <NewsCard item={n.data} />)}
    </div>
  </div>
</section>

<script>
  const root = document.getElementById("all-news");
  if (root) {
    const tabs = Array.from(
      root.querySelectorAll<HTMLButtonElement>(".course-tab"),
    );
    const cards = Array.from(root.querySelectorAll<HTMLElement>(".news"));
    let active = "全部";

    const render = () => {
      cards.forEach((card) => {
        card.hidden = !(active === "全部" || card.dataset.tag === active);
      });
      tabs.forEach((t) => {
        const on = t.dataset.tag === active;
        t.classList.toggle("is-active", on);
        t.setAttribute("aria-pressed", String(on));
      });
    };

    tabs.forEach((t) =>
      t.addEventListener("click", () => {
        active = t.dataset.tag || "全部";
        render();
      }),
    );
    render();

    // 彈出卡：原生 <dialog> 提供 ESC、backdrop 與 inert，這裡只補
    // 開關綁定、backdrop 點擊關閉與關閉後的焦點還原。
    cards.forEach((card) => {
      const dialog = card.querySelector<HTMLDialogElement>(".news-dialog");
      const opener = card.querySelector<HTMLButtonElement>(".news-link");
      if (!dialog || !opener) return;

      card.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest("dialog")) return;
        if (!dialog.open) dialog.showModal();
      });
      dialog.addEventListener("click", (e) => {
        // 內容包在 .news-dialog-inner；事件目標是 dialog 本身即點到 backdrop
        if (e.target === dialog) dialog.close();
      });
      dialog
        .querySelector(".news-dialog-close")
        ?.addEventListener("click", () => dialog.close());
      dialog.addEventListener("close", () => opener.focus());
    });
  }
</script>
