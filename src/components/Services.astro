---
import SectionHead from "./SectionHead.astro";
import { getCollection } from "astro:content";
import { withBase } from "../lib/site";

const services = (await getCollection("services")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section class="section" id="services">
  <div class="wrap">
    <SectionHead zh="服務項目" en="Our Services" />
    <div class="prod-grid prod-grid-4">
      {
        services.map((s) => (
          <a class="prod prod-link" href={withBase("/services#" + s.id)}>
            <div class="prod-disk">
              <i class={s.data.icon} aria-hidden="true" />
            </div>
            <h3>{s.data.name}</h3>
            <p>{s.data.short}</p>
            <span class="prod-go">
              了解更多 <i class="fa-solid fa-arrow-right" aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>
    <div class="center">
      <a class="btn btn-ghost" href={withBase("/services")}>查看所有服務內容</a>
    </div>
  </div>
</section>
