---
import type { CollectionEntry } from "astro:content";
import { withBase } from "../lib/site";
interface Props {
  item: CollectionEntry<"news">["data"];
}
const { item } = Astro.props;
---

<article class="news" data-tag={item.tag}>
  <img
    class="news-thumb"
    src={withBase("/assets/news/" + item.img)}
    alt=""
    loading="lazy"
    width="132"
    height="132"
  />
  <div>
    <div class="news-meta">
      <span class="badge">{item.tag}</span>
      <span class="news-date">{item.date}</span>
    </div>
    <h2>
      <button class="news-link" type="button">{item.title}</button>
    </h2>
    <p>{item.desc}</p>
  </div>

  {/* 彈出卡：完整內容留在站內呈現；原始貼文連結降級為卡內的次要按鈕 */}
  <dialog class="news-dialog" aria-label={item.title}>
    <div class="news-dialog-inner">
      <button
        class="news-dialog-close"
        type="button"
        autofocus
        aria-label="關閉"
      >
        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
      </button>
      <img
        class="news-dialog-img"
        src={withBase("/assets/news/" + item.img)}
        alt=""
        loading="lazy"
        width="560"
        height="315"
      />
      <div class="news-dialog-body">
        <div class="news-meta">
          <span class="badge">{item.tag}</span>
          <span class="news-date">{item.date}</span>
        </div>
        <h3 class="news-dialog-title">{item.title}</h3>
        <p class="news-dialog-desc">{item.desc}</p>
        {
          item.url && (
            <a
              class="news-dialog-src"
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
            >
              前往 Facebook 原文
              <i
                class="fa-solid fa-arrow-up-right-from-square"
                aria-hidden="true"
              />
            </a>
          )
        }
      </div>
    </div>
  </dialog>
</article>
