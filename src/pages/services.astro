---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import ServicesDetail from "../components/ServicesDetail.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";

const title = "服務項目 — 七維思 Kiwissec";
const description =
  "七維思的資安服務：企業資安教育訓練、顧問諮詢、檢測服務（弱點掃描 / 滲透測試 / 社交工程）與個人資安課程，皆可依產業與需求客製。";
---

<Base title={title} description={description} path="/services">
  <Navbar />
  <main id="main">
    <ServicesDetail />
    <Contact />
  </main>
  <Footer />
</Base>
